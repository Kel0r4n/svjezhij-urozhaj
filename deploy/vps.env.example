# Скопируйте на сервер: cp deploy/vps.env.example .env

POSTGRES_USER=shop
POSTGRES_PASSWORD=замените-на-сложный-пароль
POSTGRES_DB=shop

SECRET_KEY=замените-на-длинную-случайную-строку-минимум-32-символа
CORS_ORIGINS=*

# Только первый запуск (демо-товары и admin). Потом: RUN_SEED=0
RUN_SEED=1

# Ваш домен (Caddy выпустит SSL). Без домена для теста по IP: DOMAIN=:80
DOMAIN=ваш-домен.ru
