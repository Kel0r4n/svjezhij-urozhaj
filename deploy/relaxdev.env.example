# RelaxDev → проект → Переменные окружения
#
# === ПРОБНЫЙ ТАРИФ (PostgreSQL недоступен) ===
# DATABASE_URL не указывайте — entrypoint сам включит SQLite.
# После оплаты тарифа: создайте БД в проекте → DATABASE_URL подставится сам.
#
# === ОБЯЗАТЕЛЬНО ===
SECRET_KEY=замените-на-длинную-случайную-строку-минимум-32-символа
CORS_ORIGINS=*
SERVE_FRONTEND=1
RUN_SEED=1
PORT=8000

# === Платный тариф с PostgreSQL (опционально, обычно автоматически) ===
# DATABASE_URL=postgresql+psycopg://...
