# Скопируйте эти переменные в панель RelaxDev → Проект → Переменные окружения
# DATABASE_URL обычно подставляется автоматически при привязке PostgreSQL

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
SECRET_KEY=замените-на-длинную-случайную-строку-минимум-32-символа
CORS_ORIGINS=*
SERVE_FRONTEND=1
RUN_SEED=1
PORT=8000
